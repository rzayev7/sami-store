KAPITAL_TEST_MODE_ENABLED=true
KAPITAL_TEST_BASE_URL=https://txpgtst.kapitalbank.az
KAPITAL_TEST_API_PREFIX=/api
KAPITAL_TEST_USERNAME=your_test_username
KAPITAL_TEST_PASSWORD=your_test_password
KAPITAL_TEST_ORDER_TYPE_RID=Order_SMS
KAPITAL_TEST_CURRENCY=944
KAPITAL_TEST_LANGUAGE=EN
KAPITAL_TEST_CREATE_ORDER_PATH=/order
KAPITAL_TEST_GET_ORDER_PATH_TEMPLATE=/order/{orderId}/?tranDetailLevel=2&tokenDetailLevel=2&orderDetailLevel=2
# Base path; approve/decline/cancel URLs become .../return/success, .../failure, .../cancel
KAPITAL_TEST_RETURN_BASE_PATH=/api/payments/kapital/return
# Legacy alias: same value as base (do not include /success)
# KAPITAL_TEST_RETURN_PATH=/api/payments/kapital/return
KAPITAL_TEST_CALLBACK_PATH=/api/payments/kapital/callback

# Public backend base URL that Kapital gateway can call/redirect to.
BACKEND_BASE_URL=http://localhost:5000

# Frontend store URL for post-verification redirects.
STORE_BASE_URL=http://localhost:3000
