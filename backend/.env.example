# Copy to `.env` — never commit real secrets.

# ── Required ──
MONGO_URI=
JWT_SECRET=
NODE_ENV=production

# ── Frontend origin (CORS) ──
# Set to your Vercel or custom domain so browser requests are allowed.
FRONTEND_URL=https://sami-store.vercel.app

# ── URLs (used for payment redirects and email links) ──
STORE_BASE_URL=https://sami-store.vercel.app
BACKEND_BASE_URL=https://sami-store.onrender.com

# ── Cloudinary ──
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Email (Resend) ──
RESEND_API_KEY=
EMAIL_FROM=

# ── WhatsApp notifications (optional) ──
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=

# ── Epoint payment gateway ──
# EPOINT_PUBLIC_KEY=i000000001
# EPOINT_PRIVATE_KEY=YOUR_PRIVATE_KEY
# EPOINT_BASE_URL=https://epoint.az
# AZN_PER_USD=1.70
# EPOINT_CURRENCY=AZN
# EPOINT_LANGUAGE=en
# EPOINT_SUCCESS_PATH=/api/payments/epoint/return/success
# EPOINT_ERROR_PATH=/api/payments/epoint/return/error

# ── Support email shown in email templates ──
# SUPPORT_EMAIL=samistore.support@gmail.com
