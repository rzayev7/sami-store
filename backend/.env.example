# Copy to `.env` — never commit real secrets.

MONGODB_URI=
JWT_SECRET=

# Public site URL (used to resolve relative product image paths for AI imageUrl fetch)
# e.g. https://sami-store.vercel.app
# FRONTEND_URL=

# Admin AI product auto-fill (optional)
ANTHROPIC_API_KEY=
# Optional — defaults to claude-3-5-sonnet-20241022 (vision). Example: claude-sonnet-4-20250514
# ANTHROPIC_MODEL=

# Optional — comma-separated hostnames for imageUrl (SSRF allowlist). Example: res.cloudinary.com,*.cloudinary.com
# If unset, any public host passes DNS/private checks.
# AI_IMAGE_URL_ALLOWLIST=
